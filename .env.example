# -----------------------------------------------------------------------------
# Bootstrap
# -----------------------------------------------------------------------------
# All non-secret settings (symbols, strategies, indicators, GCS bucket, etc.)
# live in config.json. This file holds secrets and optional path overrides only.

CONFIG_PATH=config.json


# -----------------------------------------------------------------------------
# Schwab API — https://developer.schwab.com
# -----------------------------------------------------------------------------
# client_id  → SCHWAB_APP_KEY
# client_secret → SCHWAB_APP_SECRET
# OAuth URLs and callback_url are in config.json → schwab.*
# callback_url must match your Schwab app registration exactly (e.g. https://127.0.0.1).

SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=

# Tokens (fill after completing the authorization flow once). Access ~30 min; refresh ~7 days.
# Run: python authorize_schwab.py
# Saves locally to schwab.token_file and uploads to gs://{bucket}/{gcs.schwab_token_path}.
# Prefer schwab.token_file in config.json (default: .schwab_tokens.json) over env vars.
SCHWAB_ACCESS_TOKEN=
SCHWAB_REFRESH_TOKEN=
SCHWAB_TOKEN_FILE=


# -----------------------------------------------------------------------------
# Gmail — required when email.forward_test=true in config.json
# -----------------------------------------------------------------------------
# SMTP host, port, sender, recipients are in config.json → email.*
# https://myaccount.google.com/apppasswords

GMAIL_APP_PASSWORD=


# -----------------------------------------------------------------------------
# Google Cloud Storage — bucket name is in config.json → gcs.bucket_name
# -----------------------------------------------------------------------------
# Service account JSON with Storage Object Admin on gs://live-trading-bot (or your bucket).
# Required for authorize_schwab.py GCS upload and local GCS backfill when not using gcloud ADC.
# On a GCP VM with an attached service account, leave unset and use the VM identity instead.

GOOGLE_APPLICATION_CREDENTIALS=gcs-sa.json
GOOGLE_CLOUD_PROJECT=
