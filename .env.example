# =============================================================================
# Live Trading Bot — environment configuration template
# =============================================================================
#
# Copy this file to `.env` and fill in real values:
#
#   cp .env.example .env
#
# Never commit `.env` — it contains secrets (API keys, tokens, credentials).
#
# WorkflowConfig.from_env(), Schwab adapters, and workflow.py read these values.
# Copy to `.env`, fill secrets, then run workflow.py or module __main__ blocks.
# =============================================================================


# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------

# Application environment: development | staging | production
APP_ENV=development

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# IANA timezone for session windows and log timestamps (market data stored in UTC)
APP_TIMEZONE=America/New_York


# -----------------------------------------------------------------------------
# Schwab Developer Portal (OAuth 2.0) — REQUIRED for live + historical data
# -----------------------------------------------------------------------------
# Register an app at https://developer.schwab.com
# Callback URL must match exactly what you registered in the portal.

SCHWAB_APP_KEY=your_schwab_app_key
SCHWAB_APP_SECRET=your_schwab_app_secret

# Redirect URI registered in the Schwab developer portal
# Local dev example (HTTPS required by Schwab):
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182/callback

# Port for the local OAuth callback server (if using a built-in auth helper)
SCHWAB_CALLBACK_PORT=8182

# OAuth tokens (populate after completing the authorization flow once)
# Access tokens expire in ~30 minutes; refresh tokens in ~7 days.
SCHWAB_ACCESS_TOKEN=
SCHWAB_REFRESH_TOKEN=

# Optional: path to a JSON file where tokens are read/written automatically
SCHWAB_TOKEN_FILE=.schwab_tokens.json

# Schwab REST API base URL (do not change unless Schwab updates their docs)
SCHWAB_API_BASE_URL=https://api.schwabapi.com

# OAuth endpoints (relative to SCHWAB_API_BASE_URL)
SCHWAB_OAUTH_AUTHORIZE_PATH=/v1/oauth/authorize
SCHWAB_OAUTH_TOKEN_PATH=/v1/oauth/token


# -----------------------------------------------------------------------------
# Schwab — historical market data (BackfillExecutor / HistoricalOrchestrator)
# -----------------------------------------------------------------------------

# Market data REST base URL
SCHWAB_MARKET_DATA_BASE_URL=https://api.schwabapi.com/marketdata/v1

# Price history endpoint path or full URL (GET)
SCHWAB_PRICE_HISTORY_PATH=/marketdata/v1/pricehistory

# Trader REST base URL
SCHWAB_TRADER_BASE_URL=https://api.schwabapi.com/trader/v1

# User preference endpoint — required before streaming (also used for streamer info)
SCHWAB_USER_PREFERENCE_PATH=/trader/v1/userPreference

# Default bar interval for backfill and live ingest
# Supported in pipeline: 1m (live), 5m, 1h, 1d (aggregated or stored)
HISTORICAL_TIMEFRAME=1m

# Schwab pricehistory frequency mapping for 1-minute bars:
# frequencyType=minute, frequency=1
SCHWAB_FREQUENCY_TYPE=minute
SCHWAB_FREQUENCY=1

# Include pre-market and after-hours bars in historical requests
SCHWAB_NEED_EXTENDED_HOURS=false

# Include previous close in price history responses
SCHWAB_NEED_PREVIOUS_CLOSE=false

# How far back to sync when running historical orchestrator (ISO date, UTC)
# Schwab limits 1-minute history to roughly the last ~48 trading days.
HISTORICAL_SYNC_START_DATE=2024-01-01
HISTORICAL_SYNC_END_DATE=

# When storage is empty, bootstrap from provider earliest available data
HISTORICAL_BOOTSTRAP_IF_EMPTY=true

# Expected regular-session window for gap detection (UTC HH:MM)
# Default matches US equities RTH 09:30–16:00 ET → 14:30–21:00 UTC (EST)
# Adjust for EDT or your market calendar.
HISTORICAL_SESSION_START_UTC=14:30
HISTORICAL_SESSION_END_UTC=21:00
HISTORICAL_TRADING_DAYS_ONLY=true

# HTTP client rate limiting (Schwab market data ≈ 120 requests/minute)
MARKET_DATA_REQUESTS_PER_MINUTE=120
MARKET_DATA_REQUEST_TIMEOUT_SECONDS=30
MARKET_DATA_MAX_RETRIES=3
MARKET_DATA_RETRY_BACKOFF_SECONDS=1.0


# -----------------------------------------------------------------------------
# Live workflow — how to run
# -----------------------------------------------------------------------------
# Simulation (no network):  python workflow.py
# Live Schwab stream:       RUN_SCHWAB_STREAM=true python workflow.py
# Live trading (CAUTION):   BROKER_USE_IN_MEMORY=false + valid OAuth tokens
RUN_SCHWAB_STREAM=false

# generic = custom WebSocket URL (WEBSOCKET_URL)
# schwab  = auto-discover streamer URL via GET /userPreference
STREAM_PROVIDER=schwab

# -----------------------------------------------------------------------------
# Schwab — live streaming (StreamConnectionManager / StreamDataProcessor)
# -----------------------------------------------------------------------------
# Streaming is a two-step flow:
#   1. GET /trader/v1/userPreference → streamerSocketUrl + client IDs
#   2. WebSocket LOGIN with access token, then SUBS/ADD for symbols
#
# Leave SCHWAB_STREAMER_URL empty to auto-discover from userPreference.

SCHWAB_STREAMER_URL=

# Stream service for OHLCV candles (recommended for this workflow)
# CHART_EQUITY fields: 0=key,1=open,2=high,3=low,4=close,5=volume,6=sequence,7=chart_time_ms
SCHWAB_STREAM_SERVICE=CHART_EQUITY
SCHWAB_CHART_EQUITY_FIELDS=0,1,2,3,4,5,6,7

# Comma-separated symbols for the live watchlist
WATCHLIST_SYMBOLS=SPY,QQQ,TSLA,AMZN,NVDA

# Subscribe automatically after WebSocket connects
STREAM_SUBSCRIBE_ON_CONNECT=true

# WebSocket transport tuning
STREAM_PING_INTERVAL_SECONDS=20
STREAM_PING_TIMEOUT_SECONDS=10
STREAM_RECONNECT_BACKOFF_SECONDS=1
STREAM_MAX_RECONNECT_BACKOFF_SECONDS=60
STREAM_MAX_RECONNECT_ATTEMPTS=

# Application-level heartbeat (optional; leave empty to disable)
STREAM_HEARTBEAT_INTERVAL_SECONDS=
STREAM_HEARTBEAT_MESSAGE=

# Live bar validation
STREAM_TIMEFRAME=1m
STREAM_REQUIRE_MINUTE_ALIGNMENT=true
STREAM_DEDUP_WINDOW=500


# -----------------------------------------------------------------------------
# Google Cloud Storage — historical OHLCV persistence
# -----------------------------------------------------------------------------
# Auth: set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON path,
# or run `gcloud auth application-default login` for local development.

GCS_BUCKET_NAME=my-trading-bucket
GCS_OHLCV_PREFIX=ohlcv
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Use daily parquet partitions (recommended for intraday backfills)
GCS_USE_DAILY_PARTITIONS=true


# -----------------------------------------------------------------------------
# Live workflow (workflow.py / TradingWorkflow)
# -----------------------------------------------------------------------------

# WebSocket URL — only used when STREAM_PROVIDER=generic
# Schwab discovers streamerSocketUrl from userPreference automatically.
WEBSOCKET_URL=

# Active strategy rules (comma-separated)
# Built-in: dema_trend | supertrend_trend | supertrend_signals | rsi_mean_reversion | macd_crossover
STRATEGIES=dema_trend

# Timeframe used for indicator jobs and strategy evaluation
STRATEGY_TIMEFRAME=5m

# Higher timeframes rolled up from 1m bars (comma-separated)
AGGREGATION_TIMEFRAMES=5m,1h,1d

# Maximum buffered bars per symbol/timeframe in IndicatorCoordinator
INDICATOR_MAX_BARS=500


# -----------------------------------------------------------------------------
# Indicators — DEMA (TradingView formula)
# -----------------------------------------------------------------------------

DEMA_PERIOD=200
# Source: close | open | high | low | volume | hl2 | ohlc4 | hlc3
DEMA_SOURCE=close


# -----------------------------------------------------------------------------
# Indicators — Supertrend (TradingView formula)
# -----------------------------------------------------------------------------

SUPERTREND_ATR_PERIOD=12
# Source: hl2 (default) | close | open | high | low | ohlc4 | hlc3
SUPERTREND_SOURCE=hl2
SUPERTREND_MULTIPLIER=3.0
# true = Wilder ATR (ta.atr); false = SMA of true range
SUPERTREND_CHANGE_ATR=true


# -----------------------------------------------------------------------------
# Risk management & position tracking
# -----------------------------------------------------------------------------

# Shares/contracts per order signal
ORDER_QUANTITY=10

# Maximum absolute position size per symbol
MAX_POSITION_QUANTITY=100

# Optional exit rules (price levels; leave empty to disable)
STOP_LOSS=
TAKE_PROFIT=
TRAILING_STOP_DISTANCE=


# -----------------------------------------------------------------------------
# Schwab — accounts, positions, and order execution
# -----------------------------------------------------------------------------
# OAuth scope: enable Market Data Production + Accounts and Trading Production
# in the Schwab developer portal for the app linked to these credentials.
#
# Trader API paths (encrypted account hash in {account_hash})
SCHWAB_ACCOUNT_NUMBERS_PATH=accounts/accountNumbers
# GET /accounts (all linked accounts) and GET /accounts/{hash} (one account)
SCHWAB_ACCOUNTS_PATH=accounts
# GET/POST/DELETE /accounts/{hash}/orders and GET /accounts/{hash}/orders/{orderId}
SCHWAB_ORDERS_PATH=accounts/{account_hash}/orders
# POST /accounts/{hash}/previewOrder
SCHWAB_PREVIEW_ORDER_PATH=accounts/{account_hash}/previewOrder

# Account targeting (hash is required for GET /accounts/{accountNumber})
# Leave blank to auto-resolve the first linked account via accountNumbers.
SCHWAB_ACCOUNT_NUMBER=
SCHWAB_ACCOUNT_HASH=

# Sync broker positions into PositionTracker on workflow.start()
SCHWAB_SYNC_POSITIONS_ON_START=false

# Broker execution
# true  = simulated fills (default, safe for dev)
# false = live Schwab POST /accounts/{hash}/orders
BROKER_USE_IN_MEMORY=true
BROKER_SIMULATED_FILL_PRICE=100

# When true, submit_signal() calls POST /previewOrder instead of placing a live order
# Use this to validate payloads before setting BROKER_USE_IN_MEMORY=false
SCHWAB_PREVIEW_ORDERS=false


# -----------------------------------------------------------------------------
# Observability — health monitor & audit logging
# -----------------------------------------------------------------------------

AUDIT_LOG_PATH=logs/audit.jsonl
HEALTH_CHECK_INTERVAL_SECONDS=30

# Health thresholds
HEALTH_FEED_STALE_SECONDS=120
HEALTH_INDICATOR_STALE_SECONDS=180
HEALTH_MAX_RECONNECTS_PER_HOUR=5
HEALTH_MAX_ORDER_ROUND_TRIP_SECONDS=10
HEALTH_MODULE_SILENCE_SECONDS=300
